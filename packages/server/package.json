{
  "name": "@aily/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsup --watch --onSuccess 'node dist/index.js'",
    "build": "tsup",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.14",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["esm"],
    "target": "node22",
    "clean": true,
    "sourcemap": true,
    "external": ["node-pty"]
  }
}
