{
  "name": "@aily/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "termhub": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "target": "node22",
    "clean": true,
    "sourcemap": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  }
}
